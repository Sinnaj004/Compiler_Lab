// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/ubuntu
{
	"name": "CompilerVM",
	// If you are under ARM-based macs, change the image to
	// skogsbaer/compiler-construction-wasm_linux-arm64:latest
	"image": "skogsbaer/compiler-construction-wasm_linux-amd64:latest",
	"workspaceMount": "source=${localWorkspaceFolder},target=/cc,type=bind",
	"workspaceFolder": "/cc",
	"customizations": {
		"vscode": {
		"extensions": [
			"ms-python.python"
		],
		"settings": {
			"python.defaultInterpreterPath": "/usr/bin/python3",
		    "python.analysis.diagnosticMode": "workspace"
		}
	}
  }
}
